# ===== Medusa Scans — Public Site environment =====
# Copy this file to .env.local (dev) or set these in your VPS / host.
# Do NOT commit real secrets.

# Public site origin (used for canonical, OG tags, Discord redirect, sitemap).
# Local dev: http://localhost:3000   Production: https://yourdomain.com
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ----- Discord OAuth -----
NEXT_PUBLIC_DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=

# ----- Cloudflare R2 (cover/banner CDN) — used by the admin, optional for the site -----
# Public base URL of the R2 bucket (custom domain or *.r2.dev). Used to render cover images.
NEXT_PUBLIC_R2_PUBLIC_URL=

# ----- Optional: remote manga catalog (if serving manga.json from R2 instead of the local file) -----
# NEXT_PUBLIC_CATALOG_URL=

# ----- Firebase (client SDK) -----
# These are public values (safe to expose) but kept here for per-environment config.
# Currently the values are inlined in src/lib/firebase.ts; move them here if you prefer.
# NEXT_PUBLIC_FIREBASE_API_KEY=
# NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
# NEXT_PUBLIC_FIREBASE_PROJECT_ID=
# NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
# NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
# NEXT_PUBLIC_FIREBASE_APP_ID=
